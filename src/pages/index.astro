---
import { getCollection } from "astro:content";
import BaseLayout from "../layouts/BaseLayout.astro";
import Nav from "../components/astro/Nav.astro";
import Footer from "../components/astro/Footer.astro";
import ProjectCard from "../components/astro/ProjectCard.astro";
import Hero3D from "../components/react/Hero3D.tsx";
import GitHubStats from "../components/react/GitHubStats.tsx";
import { EMAIL } from "../lib/social";

const projects = (await getCollection("projects")).sort((a, b) => a.data.order - b.data.order);
---

<BaseLayout description="Designer-developer shipping three real cross-platform apps.">
  <Nav />
  <main class="mx-auto max-w-6xl px-5 sm:px-8 lg:px-12">
    <!-- HERO -->
    <section class="pt-10">
      <div
        class="flex flex-wrap items-center gap-x-6 gap-y-2 border-b border-line pb-3 font-mono text-[11px] uppercase tracking-[0.16em] text-steel"
      >
        <span class="text-acid">// PORTFOLIO</span>
        <span>REV 2026.06</span>
        <span class="flex-1"></span>
        <span class="text-secondary">WORKSTATION_01</span>
        <span>03 SHIPPED PRODUCTS</span>
        <span>40.7440&deg;N 73.9873&deg;W</span>
      </div>

      <div class="relative pt-6">
        <!-- machine illustration (desktop: big, right) -->
        <div class="absolute right-0 top-1/2 z-0 hidden w-[50%] max-w-[600px] -translate-y-1/2 md:block lg:-right-4">
          <div class="relative" style="aspect-ratio: 1856 / 1788">
            <!-- soft periwinkle bloom behind the illustration, fading into the void -->
            <div
              class="absolute inset-0 z-0"
              style="background: radial-gradient(50% 46% at 54% 42%, rgba(156, 162, 210, 0.1), transparent 72%)"
            >
            </div>
            <!-- illustration sits on transparency; its native near-black ground melts into the page -->
            <img
              src="/hero-machine.webp"
              alt="Operator workstation — vintage terminal"
              fetchpriority="high"
              class="relative z-[1] h-full w-full object-contain"
            />
            <!-- CRT screen renders the live 3D specimen -->
            <div class="absolute z-[3] overflow-hidden" style="left: 29%; top: 11.5%; width: 40%; height: 30%">
              <Hero3D client:visible />
              <div
                class="pointer-events-none absolute inset-0 mix-blend-overlay"
                style="background: repeating-linear-gradient(0deg, transparent 0 2px, rgba(0,0,0,0.45) 2px 3px)"
              >
              </div>
            </div>
          </div>
        </div>

        <!-- headline content overlay -->
        <div class="relative z-10 flex flex-col md:min-h-[540px]">
          <div class="font-mono text-[11px] uppercase tracking-[0.14em] text-steel">
            (N&deg;001) &mdash; Designer / Developer
          </div>
          <h1
            class="mt-3 font-display text-[clamp(64px,16vw,124px)] uppercase leading-[0.85] tracking-[0.01em] [text-shadow:0_2px_24px_rgba(10,11,10,0.92)]"
          >
            I design it<br />and I <span class="text-acid">ship it.</span>
          </h1>
          <div class="acid-stripe my-6 h-2.5 w-full max-w-sm md:my-7"></div>
          <p class="max-w-[42ch] font-sub text-[15px] font-medium leading-[1.6] text-bone/85 [text-shadow:0_1px_12px_rgba(10,11,10,0.9)]">
            Three real apps, designed and engineered end to end &mdash; <span class="text-bone">iOS, Android &amp; web</span>.
            From React Three Fiber interfaces to Supabase backends. No mockups. Live software.
          </p>

          <!-- mobile machine: inline under the copy, with the live 3D specimen in its CRT -->
          <div class="relative mx-auto mt-9 w-full max-w-[300px] md:hidden">
            <div class="relative" style="aspect-ratio: 1856 / 1788">
              <div
                class="absolute inset-0 z-0"
                style="background: radial-gradient(50% 46% at 54% 42%, rgba(156, 162, 210, 0.1), transparent 72%)"
              >
              </div>
              <img
                src="/hero-machine.webp"
                alt="Operator workstation — vintage terminal"
                fetchpriority="high"
                class="relative z-[1] h-full w-full object-contain"
              />
              <div class="absolute z-[3] overflow-hidden" style="left: 29%; top: 11.5%; width: 40%; height: 30%">
                <Hero3D client:visible />
                <div
                  class="pointer-events-none absolute inset-0 mix-blend-overlay"
                  style="background: repeating-linear-gradient(0deg, transparent 0 2px, rgba(0,0,0,0.45) 2px 3px)"
                >
                </div>
              </div>
            </div>
          </div>

          <div
            class="mt-10 flex flex-wrap items-center gap-x-6 gap-y-2 font-mono text-[11px] uppercase tracking-[0.1em] text-steel md:mt-auto md:pt-10"
          >
            <GitHubStats client:visible />
            <span>SINCE 2021</span>
            <a href="#work" class="text-acid underline-offset-4 hover:underline">See the work &#8595;</a>
          </div>
        </div>
      </div>
    </section>

    <!-- WORK -->
    <section id="work" class="scroll-mt-20 pt-24">
      <div class="flex flex-wrap items-center justify-between gap-4 border-b border-line pb-3">
        <span class="font-mono text-[11px] uppercase tracking-[0.16em] text-acid"
          >// Selected work</span
        >
        <h2 class="font-display text-[30px] uppercase tracking-[0.02em]">The Work</h2>
        <span class="font-mono text-[11px] uppercase tracking-[0.12em] text-steel"
          >Three flagships &mdash; each <span class="text-bone">live</span> &amp; <span class="text-bone">open source</span></span
        >
      </div>
      <div class="mt-6 grid gap-4 md:grid-cols-3">
        {projects.map((project) => <ProjectCard project={project} />)}
      </div>
      <div
        class="mt-6 flex flex-wrap items-center justify-between gap-x-6 gap-y-3 border-t border-line pt-4 font-mono text-[11px] uppercase tracking-[0.12em] text-steel"
      >
        <span>Shown in depth, on purpose &mdash; not the whole repo list</span>
        <a
          href="https://github.com/ginoleeswan"
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-2 text-acid underline-offset-4 hover:underline"
        >
          More on GitHub &#8599;
        </a>
      </div>
    </section>

    <!-- CONTACT -->
    <section id="contact" class="scroll-mt-20 pt-28">
      <div class="border-b border-line pb-3 font-mono text-[11px] uppercase tracking-[0.16em] text-acid">
        // Transmission
      </div>
      <div class="grid items-end gap-8 pt-8 md:grid-cols-[1.4fr_1fr]">
        <h2 class="font-display text-[clamp(48px,7vw,92px)] uppercase leading-[0.85]">
          Let&rsquo;s build<br />something <span class="text-acid">real.</span>
        </h2>
        <div class="font-mono text-[12px] leading-relaxed text-steel">
          <p class="mb-5 font-sub text-[15px] font-medium text-bone/85">Have a product in mind, or a role to fill? Open a channel.</p>
          <a
            href={`mailto:${EMAIL}`}
            class="inline-flex items-center gap-3 bg-flare px-6 py-3 font-sub text-[14px] font-black uppercase tracking-[0.04em] text-void transition-transform hover:-translate-y-0.5"
          >
            {EMAIL} &#8599;
          </a>
        </div>
      </div>
    </section>
  </main>
  <Footer />
</BaseLayout>
