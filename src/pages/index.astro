---
import { getCollection } from "astro:content";
import BaseLayout from "../layouts/BaseLayout.astro";
import Nav from "../components/astro/Nav.astro";
import Footer from "../components/astro/Footer.astro";
import ProjectCard from "../components/astro/ProjectCard.astro";
import Hero3D from "../components/react/Hero3D.tsx";
import GitHubStats from "../components/react/GitHubStats.tsx";
import { EMAIL } from "../lib/social";

const projects = (await getCollection("projects")).sort((a, b) => a.data.order - b.data.order);
---

<BaseLayout description="Designer-developer shipping three real cross-platform apps.">
  <Nav />
  <main class="mx-auto max-w-6xl px-12">
    <!-- HERO -->
    <section class="pt-10">
      <div
        class="flex flex-wrap items-center gap-x-6 gap-y-2 border-b border-line pb-3 font-mono text-[11px] uppercase tracking-[0.16em] text-steel"
      >
        <span class="text-acid">// PORTFOLIO</span>
        <span>REV 2026.06</span>
        <span class="flex-1"></span>
        <span>03 SHIPPED PRODUCTS</span>
        <span>40.7440&deg;N 73.9873&deg;W</span>
      </div>

      <div class="grid gap-10 pt-10 md:grid-cols-[1.5fr_1fr]">
        <div class="flex flex-col">
          <div class="font-mono text-[11px] uppercase tracking-[0.14em] text-steel">
            (N&deg;001) &mdash; Designer / Developer
          </div>
          <h1 class="mt-3 font-display text-[clamp(64px,9vw,116px)] uppercase leading-[0.85] tracking-[0.01em]">
            Built to<br />be <span class="text-acid">shipped.</span>
          </h1>
          <div class="acid-stripe my-7 h-2.5 w-full max-w-md"></div>
          <p class="max-w-[48ch] font-mono text-[13px] leading-[1.7] text-bone/80">
            Three real apps, designed and engineered end to end &mdash; <span class="text-bone">iOS, Android &amp; web</span>.
            From React Three Fiber interfaces to Supabase backends. No mockups. Live software.
          </p>
          <div
            class="mt-auto flex flex-wrap items-center gap-6 pt-8 font-mono text-[11px] uppercase tracking-[0.1em] text-steel"
          >
            <GitHubStats client:visible />
            <span>SINCE 2021</span>
            <a href="#work" class="text-acid underline-offset-4 hover:underline">See the work &#8595;</a>
          </div>
        </div>

        <!-- right: 3D render + operator specimen -->
        <div class="flex flex-col gap-3 md:border-l md:border-line md:pl-7">
          <div class="relative h-[230px] border border-line">
            <div class="absolute left-3 top-2 z-10 font-mono text-[10px] uppercase tracking-[0.12em] text-steel">
              RENDER_00 / LIVE
            </div>
            <Hero3D client:visible />
          </div>
          <!-- operator photo specimen: 1-bit dithered portrait -->
          <div
            class="halftone relative h-[300px] overflow-hidden border border-line"
            style="background: radial-gradient(120% 140% at 60% 0%, #16240f, #0a0b0a 72%)"
          >
            <img
              src="/gino-portrait.png"
              alt="Gino Swanepoel — 1-bit dithered portrait"
              loading="lazy"
              decoding="async"
              class="pointer-events-none absolute inset-0 z-[1] h-full w-full object-cover object-top"
            />
            <div class="pointer-events-none absolute inset-x-0 bottom-0 z-[2] h-20 bg-gradient-to-t from-void to-transparent"></div>
            <div class="absolute left-3 top-2 z-[3] font-mono text-[10px] uppercase tracking-[0.1em] text-steel">
              SPECIMEN_00 / OPERATOR
            </div>
            <div class="absolute right-3 top-2 z-[3] font-sub text-[26px] font-black leading-none text-acid drop-shadow-[0_2px_6px_rgba(0,0,0,0.7)]">
              &#12463;&#12522;&#12456;&#12452;&#12479;&#12540;
            </div>
            <div class="absolute bottom-2 left-3 z-[3] font-mono text-[10px] uppercase tracking-[0.12em] text-bone">
              G. Swanepoel &mdash; operator
            </div>
          </div>
          <div class="barcode h-7 opacity-80"></div>
          <div class="flex justify-between font-mono text-[10px] uppercase tracking-[0.1em] text-steel">
            <span>ID 1696&middot;4567</span><span>Cape Town / ZA</span>
          </div>
        </div>
      </div>
    </section>

    <!-- WORK -->
    <section id="work" class="scroll-mt-20 pt-24">
      <div class="flex flex-wrap items-center justify-between gap-4 border-b border-line pb-3">
        <span class="font-mono text-[11px] uppercase tracking-[0.16em] text-acid"
          >// Selected work &mdash; 003 specimens</span
        >
        <h2 class="font-display text-[30px] uppercase tracking-[0.02em]">The Work</h2>
        <span class="font-mono text-[11px] uppercase tracking-[0.12em] text-steel">Open a specimen for the dossier</span>
      </div>
      <div class="mt-6 grid gap-4 md:grid-cols-3">
        {projects.map((project) => <ProjectCard project={project} />)}
      </div>
    </section>

    <!-- CONTACT -->
    <section id="contact" class="scroll-mt-20 pt-28">
      <div class="border-b border-line pb-3 font-mono text-[11px] uppercase tracking-[0.16em] text-acid">
        // Transmission
      </div>
      <div class="grid items-end gap-8 pt-8 md:grid-cols-[1.4fr_1fr]">
        <h2 class="font-display text-[clamp(48px,7vw,92px)] uppercase leading-[0.85]">
          Let&rsquo;s build<br />something <span class="text-acid">real.</span>
        </h2>
        <div class="font-mono text-[12px] leading-relaxed text-steel">
          <p class="mb-5 text-bone/80">Have a product in mind, or a role to fill? Open a channel.</p>
          <a
            href={`mailto:${EMAIL}`}
            class="inline-flex items-center gap-3 bg-flare px-6 py-3 font-sub text-[14px] font-black uppercase tracking-[0.04em] text-void transition-transform hover:-translate-y-0.5"
          >
            {EMAIL} &#8599;
          </a>
        </div>
      </div>
    </section>
  </main>
  <Footer />
</BaseLayout>
