---
import { Icon } from "astro-icon/components";
import BaseLayout from "../layouts/BaseLayout.astro";
import Nav from "../components/astro/Nav.astro";
import Footer from "../components/astro/Footer.astro";
import { SOCIALS, EMAIL } from "../lib/social";
import { socialIcon } from "../lib/icons";

// Derivco tenure, computed at build so it never goes stale (started Jan 2022).
const derivcoStart = new Date(2022, 0, 1);
const tenureMonths =
  (new Date().getFullYear() - derivcoStart.getFullYear()) * 12 +
  (new Date().getMonth() - derivcoStart.getMonth());
const derivcoYears = (Math.round((tenureMonths / 12) * 2) / 2).toFixed(1);
---

<BaseLayout title="About" description="About Gino Swanepoel — designer-developer.">
  <Nav />
  <main class="mx-auto max-w-5xl px-5 sm:px-8 lg:px-12">
    <section class="pt-10">
      <div
        class="flex flex-wrap items-center gap-x-6 gap-y-2 border-b border-line pb-3 font-mono text-[11px] uppercase tracking-[0.16em] text-steel"
      >
        <span class="text-acid">// Operator file</span>
        <span>(N&deg;000)</span>
        <span class="flex-1"></span>
        <span>40.7440&deg;N 73.9873&deg;W</span>
      </div>

      <div class="grid gap-12 pt-12 md:grid-cols-[1.4fr_1fr]">
        <div>
          <h1 class="font-display text-[clamp(56px,9vw,120px)] uppercase leading-[0.85]">
            About<br /><span class="text-acid">the operator.</span>
          </h1>
          <div class="mt-8 max-w-[60ch] space-y-4 font-sub text-[16px] font-medium leading-[1.7] text-bone/85">
            <p>
              I&rsquo;m <span class="text-bone">Gino Swanepoel</span> &mdash; a designer-developer who builds
              cross-platform apps end to end. Interfaces, motion, backends, ship.
            </p>
            <p>
              By day, a <span class="text-bone">Software Developer II at Derivco</span> in Cape Town &mdash; {derivcoYears}+ years
              shipping production software on a large engineering team. The products in this portfolio are what I design and
              build on my own time, front to back.
            </p>
            <p>
              I work in the seam between design and engineering: React Three Fiber and brutalist UI on the front,
              Supabase, TypeScript, and AI on the back. Real, shipped software &mdash; not concepts.
            </p>
          </div>
          <a
            href={`mailto:${EMAIL}?subject=Résumé%20request`}
            class="mt-10 inline-flex items-center gap-3 bg-acid px-6 py-3 font-sub text-[14px] font-black uppercase tracking-[0.04em] text-void transition-transform hover:-translate-y-0.5"
            >Request résumé &#8599;</a
          >
        </div>

        <!-- operator specimen + channels -->
        <div class="border-line md:border-l md:pl-8">
          <div
            class="halftone relative mb-8 h-[300px] overflow-hidden border border-line"
            style="background: radial-gradient(120% 140% at 60% 0%, #16240f, #0a0b0a 72%)"
          >
            <img
              src="/gino-portrait.webp"
              alt="Gino Swanepoel — 1-bit dithered portrait"
              loading="lazy"
              decoding="async"
              class="pointer-events-none absolute inset-0 z-[1] h-full w-full object-cover object-top"
            />
            <div class="pointer-events-none absolute inset-x-0 bottom-0 z-[2] h-20 bg-gradient-to-t from-void to-transparent"></div>
            <div class="absolute left-3 top-2 z-[3] font-mono text-[10px] uppercase tracking-[0.1em] text-steel">
              SPECIMEN_00 / OPERATOR
            </div>
            <div class="absolute right-3 top-2 z-[3] font-sub text-[26px] font-black leading-none text-acid drop-shadow-[0_2px_6px_rgba(0,0,0,0.7)]">
              &#12463;&#12522;&#12456;&#12452;&#12479;&#12540;
            </div>
            <div class="absolute bottom-2 left-3 z-[3] font-mono text-[10px] uppercase tracking-[0.12em] text-bone">
              G. Swanepoel &mdash; operator
            </div>
          </div>
          <div class="mb-4 font-mono text-[11px] uppercase tracking-[0.16em] text-acid">// Channels</div>
          <table class="w-full border-collapse font-mono text-[12px]">
            <tbody>
              {
                SOCIALS.map((s) => (
                  <tr class="border-b border-line">
                    <td class="py-3 pr-4 uppercase tracking-[0.1em] text-steel">
                      <span class="inline-flex items-center gap-2">
                        {socialIcon(s.label) && <Icon name={socialIcon(s.label)!} class="h-3.5 w-3.5" />}
                        {s.label}
                      </span>
                    </td>
                    <td class="py-3 text-right">
                      <a href={s.href} target="_blank" rel="noopener noreferrer" class="text-bone hover:text-acid">
                        OPEN &#8599;
                      </a>
                    </td>
                  </tr>
                ))
              }
              <tr class="border-b border-line">
                <td class="py-3 pr-4 uppercase tracking-[0.1em] text-steel">Email</td>
                <td class="py-3 text-right">
                  <a href={`mailto:${EMAIL}`} class="text-acid">{EMAIL}</a>
                </td>
              </tr>
            </tbody>
          </table>
          <div class="barcode mt-8 h-8 opacity-80"></div>
          <div class="mt-2 font-mono text-[10px] uppercase tracking-[0.1em] text-steel">ID 1696&middot;4567 / OPERATOR</div>
        </div>
      </div>
    </section>

    <!-- SERVICE RECORD -->
    <section class="pt-16">
      <div
        class="flex flex-wrap items-center gap-x-6 gap-y-2 border-b border-line pb-3 font-mono text-[11px] uppercase tracking-[0.16em] text-steel"
      >
        <span class="text-acid">// Service record</span>
        <span class="flex-1"></span>
        <span class="inline-flex items-center gap-2 text-secondary">
          <span class="inline-block h-[7px] w-[7px] rounded-full bg-acid"></span>Active duty
        </span>
      </div>

      <article class="mt-8 grid gap-x-8 gap-y-4 md:grid-cols-[1fr_auto] md:items-start">
        <div>
          <div class="flex flex-wrap items-baseline gap-x-3 gap-y-1">
            <h2 class="font-display text-[clamp(34px,5vw,56px)] uppercase leading-[0.9]">Derivco</h2>
            <span class="font-mono text-[11px] uppercase tracking-[0.14em] text-steel">Cape Town, ZA</span>
          </div>
          <div class="mt-2 font-sub text-[15px] font-bold uppercase tracking-[0.04em] text-acid">Software Developer II</div>
          <!-- TODO(gino): replace with the specific work you shipped at Derivco (systems, stack, impact) -->
          <p class="mt-4 max-w-[60ch] font-sub text-[15px] font-medium leading-[1.7] text-bone/85">
            Building and shipping production software on a cross-functional engineering team.
          </p>
        </div>
        <div class="font-mono text-[11px] uppercase tracking-[0.12em] text-steel md:text-right">
          <div class="text-bone">2022 &mdash; Present</div>
          <div class="mt-1">{derivcoYears} yrs in seat</div>
        </div>
      </article>
    </section>
  </main>
  <Footer />
</BaseLayout>
