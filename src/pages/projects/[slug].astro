---
import { Icon } from "astro-icon/components";
import { getCollection, type CollectionEntry } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";
import Nav from "../../components/astro/Nav.astro";
import Footer from "../../components/astro/Footer.astro";
import TechRow from "../../components/astro/TechRow.astro";
import { PROJECT_THEMES } from "../../lib/projectThemes";
import { platformIcon } from "../../lib/icons";

export async function getStaticPaths() {
  const projects = await getCollection("projects");
  return projects.map((project) => ({ params: { slug: project.data.slug }, props: { project } }));
}

const { project } = Astro.props as { project: CollectionEntry<"projects"> };
const { title, tagline, techStack, liveUrl, repoUrl, slug, role, year, accent, kana, order, gallery, heroImage, heroInset } =
  project.data;
const { platforms, problem, approach, decisions, challenge, metrics } = project.data;

const t = PROJECT_THEMES[accent];
const no = String(order).padStart(2, "0");
const logoName = accent === "myth" ? "mythique" : accent === "glow" ? "glow" : "karma";

// prev / next specimen, cycling with wrap-around
const all = (await getCollection("projects")).sort((a, b) => a.data.order - b.data.order);
const idx = all.findIndex((p) => p.data.slug === slug);
const prev = all[(idx - 1 + all.length) % all.length].data;
const next = all[(idx + 1) % all.length].data;
const prevNo = String(prev.order).padStart(2, "0");
const nextNo = String(next.order).padStart(2, "0");
const prevGlyph = PROJECT_THEMES[prev.accent].glyph;
const nextGlyph = PROJECT_THEMES[next.accent].glyph;

// the technical write-up tied to this project, if one exists
const post = (await getCollection("writing")).find((p) => p.data.projectSlug === slug);
---

<BaseLayout title={title} description={tagline}>
  {/* preload neighbouring posters' screenshots so prev/next switching is instant */}
  <link rel="preload" as="image" href={prev.heroImage} />
  <link rel="preload" as="image" href={next.heroImage} />
  <Nav />
  <main>
    <!-- DUOTONE DOSSIER HEADER — wrapper carries the view-transition so the screenshot morphs WITH the poster (one group, no behind/front flip) -->
    <div class="relative" style="view-transition-name: dossier-poster">
    <header
      class="halftone relative overflow-hidden px-5 pb-12 pt-16 sm:px-8 lg:px-12"
      style={`background:
        radial-gradient(125% 125% at 16% 0%, ${t.bgFrom}, ${t.bgMid} 52%, ${t.bgTo})`}
    >
      <Icon
        name={logoName}
        class="pointer-events-none absolute -right-10 -top-10 z-[1] h-72 w-72 opacity-[0.12]"
        style={`color:${t.name}`}
      />
      <div class="relative z-[6] mx-auto max-w-5xl">
        <div class="flex items-center justify-between font-mono text-[11px] uppercase tracking-[0.14em]" style={`color:${t.chrome}`}>
          <a href="/#work" style={`color:${t.chrome}`}>&#8592; Index</a>
          <span>Dossier N&deg;{no} / {year}</span>
        </div>
        <div
          class="pointer-events-none absolute right-0 top-4 hidden font-sub text-[44px] font-black leading-none opacity-90 sm:block"
          style={`color:${t.glyph}; writing-mode: vertical-rl`}
        >
          {kana}
        </div>
        <div class="mt-8 flex items-center gap-4">
          <Icon name={logoName} class="h-14 w-14" style={`color:${t.name}`} />
          <span class="font-mono text-[12px] uppercase tracking-[0.18em]" style={`color:${t.body}`}>Specimen {no}</span>
        </div>
        <h1 class="mt-4 font-display text-[clamp(56px,11vw,150px)] uppercase leading-[0.82] tracking-[0.01em]" style={`view-transition-name: title-${slug}; color:${t.name}`}>
          {title}
        </h1>
        <p class="mt-4 max-w-[44ch] font-mono text-[14px] leading-relaxed" style={`color:${t.body}`}>{tagline}</p>
        <div class="mt-7 flex flex-wrap gap-3">
          {
            liveUrl && (
              <a
                href={liveUrl}
                target="_blank"
                rel="noopener noreferrer"
                class="bg-void px-5 py-2.5 font-sub text-[13px] font-black uppercase tracking-[0.04em] text-acid transition-transform hover:-translate-y-0.5"
              >
                Live demo &#8599;
              </a>
            )
          }
          <a
            href={repoUrl}
            target="_blank"
            rel="noopener noreferrer"
            class="border-2 px-5 py-2.5 font-sub text-[13px] font-black uppercase tracking-[0.04em] transition-transform hover:-translate-y-0.5"
            style={`border-color:${t.name}; color:${t.name}`}>GitHub &#8599;</a
          >
        </div>
      </div>
    </header>
    <!-- product screenshot — fills the poster's right, bleeds slightly over the seam (desktop only) -->
    <div class="pointer-events-none absolute inset-x-0 bottom-0 z-[5] mx-auto hidden max-w-5xl px-5 sm:px-8 md:block lg:px-12">
      <img
        src={heroImage}
        alt={`${title} — product screenshot`}
        fetchpriority="high"
        decoding="sync"
        class="absolute bottom-[-32px] max-h-[340px] w-auto max-w-[48%] rounded-2xl object-contain object-bottom lg:max-h-[400px]"
        style={`right:${heroInset}; mix-blend-mode:${t.light ? "multiply" : "screen"}; box-shadow:0 18px 50px rgba(0,0,0,0.28)`}
      />
    </div>
    </div>

    <!-- DOSSIER BODY -->
    <div class="mx-auto max-w-5xl px-5 py-12 sm:px-8 lg:px-12">
      <!-- SPEC BAR — glanceable facts -->
      <div class="flex flex-wrap items-center gap-x-6 gap-y-3 border-y border-line py-4 font-mono text-[11px] uppercase tracking-[0.12em] text-steel">
        <div class="flex items-center gap-4">
          {
            platforms.map((p) => (
              <span class="inline-flex items-center gap-1.5 text-bone">
                <Icon name={platformIcon(p)} class="h-4 w-4" />
                {p}
              </span>
            ))
          }
        </div>
        <span class="hidden h-3.5 w-px bg-line sm:block"></span>
        <span class="inline-flex items-center gap-1.5"><Icon name="lucide:user" class="h-3.5 w-3.5" />{role}</span>
        <span class="inline-flex items-center gap-1.5"><Icon name="lucide:calendar" class="h-3.5 w-3.5" />{year}</span>
        <span class="flex-1"></span>
        <span class="inline-flex items-center gap-2 text-acid">
          <span class="inline-block h-[7px] w-[7px] rounded-full bg-acid"></span>Shipped
        </span>
      </div>

      <!-- AT A GLANCE — problem + build -->
      <div class="mt-10 grid gap-4 md:grid-cols-2">
        <div class="border border-line bg-void/80 p-5">
          <div class="flex items-center gap-2 font-mono text-[11px] uppercase tracking-[0.16em] text-acid">
            <Icon name="lucide:target" class="h-4 w-4" />// The problem
          </div>
          <p class="mt-3 font-sub text-[15px] font-medium leading-[1.6] text-bone/85">{problem}</p>
        </div>
        <div class="border border-line bg-void/80 p-5">
          <div class="flex items-center gap-2 font-mono text-[11px] uppercase tracking-[0.16em] text-acid">
            <Icon name="lucide:hammer" class="h-4 w-4" />// What I built
          </div>
          <p class="mt-3 font-sub text-[15px] font-medium leading-[1.6] text-bone/85">{approach}</p>
        </div>
      </div>

      <!-- STACK -->
      <div class="mt-14 mb-5 flex items-center gap-4 border-b border-line pb-3 font-mono text-[11px] uppercase tracking-[0.16em] text-steel">
        <span class="text-acid">// Stack</span><span>{techStack.length} tools, end to end</span>
      </div>
      <TechRow items={techStack} />

      {
        gallery.length > 0 && (
          <section class="mt-14">
            <div class="mb-5 flex items-center gap-4 border-b border-line pb-3 font-mono text-[11px] uppercase tracking-[0.16em] text-steel">
              <span class="text-acid">// Stills</span>
              <span>{String(gallery.length).padStart(2, "0")} frames &mdash; scroll &#8594;</span>
            </div>
            <div class="-mx-5 flex snap-x snap-mandatory gap-4 overflow-x-auto px-5 pb-4 sm:-mx-8 sm:px-8 lg:-mx-12 lg:px-12 [scrollbar-color:var(--color-line)_transparent] [scrollbar-width:thin]">
              {gallery.map((g, i) => (
                <figure class="shrink-0 snap-start">
                  <div class="halftone relative h-[400px] overflow-hidden rounded-xl border border-line bg-void">
                    <img
                      src={g.src}
                      alt={`${title} — ${g.label}`}
                      loading="lazy"
                      decoding="async"
                      class="relative z-[1] block h-full w-auto max-w-none object-contain"
                    />
                  </div>
                  <figcaption class="mt-2 font-mono text-[10px] uppercase tracking-[0.12em] text-steel">
                    <span class="text-acid">{String(i + 1).padStart(2, "0")}</span> &mdash; {g.label}
                  </figcaption>
                </figure>
              ))}
            </div>
          </section>
        )
      }

      <!-- DECISIONS — icon cards -->
      <div class="mt-16 mb-6 flex items-center gap-4 border-b border-line pb-3 font-mono text-[11px] uppercase tracking-[0.16em] text-steel">
        <span class="text-acid">// Decisions</span><span>{String(decisions.length).padStart(2, "0")} that mattered</span>
      </div>
      <div class="grid gap-4 md:grid-cols-2">
        {
          decisions.map((d) => (
            <div class="border border-line bg-void/80 p-6">
              <Icon name={d.icon} class="h-7 w-7 text-acid" />
              <h3 class="mt-4 font-sub text-[18px] font-bold leading-tight text-bone">{d.title}</h3>
              <p class="mt-2 font-sub text-[14px] font-medium leading-[1.6] text-bone/85">{d.body}</p>
            </div>
          ))
        }
      </div>

      <!-- WHAT WAS HARD — callout -->
      <div class="mt-4 flex items-start gap-4 border border-line border-l-2 border-l-acid bg-void/80 p-6">
        <Icon name="lucide:flame" class="mt-0.5 h-6 w-6 shrink-0 text-acid" />
        <div>
          <div class="font-mono text-[11px] uppercase tracking-[0.16em] text-acid">// What was hard</div>
          <p class="mt-2 font-sub text-[15px] font-medium leading-[1.6] text-bone/85">{challenge}</p>
        </div>
      </div>

      <!-- OUTCOME — metric tiles -->
      <div class="mt-16 mb-6 flex items-center gap-4 border-b border-line pb-3 font-mono text-[11px] uppercase tracking-[0.16em] text-steel">
        <span class="text-acid">// Outcome</span>
      </div>
      <div class="grid grid-cols-2 gap-4 sm:grid-cols-3">
        {
          metrics.map((m) => (
            <div class="border border-line bg-void/80 p-6">
              <Icon name={m.icon} class="h-6 w-6 text-acid" />
              <div class="mt-4 font-display text-[44px] leading-none text-bone">{m.value}</div>
              <div class="mt-2 font-mono text-[11px] uppercase tracking-[0.12em] text-steel">{m.label}</div>
            </div>
          ))
        }
      </div>

      {
        post && (
          <a
            href={`/writing/${post.data.slug}`}
            class="group mt-12 flex items-center justify-between gap-4 border border-line p-5 no-underline transition-colors hover:border-acid"
          >
            <span class="min-w-0">
              <span class="block font-mono text-[11px] uppercase tracking-[0.16em] text-acid">// Read the write-up</span>
              <span class="mt-1 block font-sub text-[17px] font-bold text-bone group-hover:text-acid">{post.data.title}</span>
              <span class="mt-1 block font-mono text-[11px] uppercase tracking-[0.1em] text-steel">
                {post.data.readingMinutes} min read &middot; the decision behind this build
              </span>
            </span>
            <span class="shrink-0 font-display text-[32px] leading-none text-acid">&#8599;</span>
          </a>
        )
      }

      <!-- mobile prev / next -->
      <nav class="mt-16 flex items-stretch justify-between gap-3 border-t border-line pt-6 font-mono text-[11px] uppercase tracking-[0.12em] md:hidden">
        <a href={`/projects/${prev.slug}`} data-cycle="prev" class="flex items-center gap-2 text-steel hover:text-acid">
          &#8592; <span>{prev.title}</span>
        </a>
        <a href={`/projects/${next.slug}`} data-cycle="next" class="flex items-center gap-2 text-steel hover:text-acid">
          <span>{next.title}</span> &#8594;
        </a>
      </nav>
    </div>

    <!-- PREV (left edge) -->
    <a
      href={`/projects/${prev.slug}`}
      data-cycle="prev"
      aria-label={`Previous specimen: ${prev.title}`}
      class="group fixed left-0 top-1/2 z-40 hidden h-44 -translate-y-1/2 items-center md:flex"
    >
      <span class="flex h-full w-11 items-center justify-center border-r border-bone/15 bg-void/35 text-bone/70 backdrop-blur-sm transition-colors duration-200 group-hover:bg-void/65 group-hover:text-acid">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" class="h-7 w-7"><path d="m15 18-6-6 6-6"></path></svg>
      </span>
      <span
        class="pointer-events-none ml-1 flex max-w-[40vw] -translate-x-3 flex-col gap-0.5 border border-line bg-void/85 px-3 py-2 opacity-0 backdrop-blur-sm transition-all duration-300 group-hover:translate-x-0 group-hover:opacity-100"
      >
        <span class="font-mono text-[10px] uppercase tracking-[0.16em] text-steel">&#8592; Prev / N&deg;{prevNo}</span>
        <span class="truncate font-display text-[30px] uppercase leading-none" style={`color:${prevGlyph}`}>{prev.title}</span>
      </span>
    </a>

    <!-- NEXT (right edge) -->
    <a
      href={`/projects/${next.slug}`}
      data-cycle="next"
      aria-label={`Next specimen: ${next.title}`}
      class="group fixed right-0 top-1/2 z-40 hidden h-44 -translate-y-1/2 flex-row-reverse items-center md:flex"
    >
      <span class="flex h-full w-11 items-center justify-center border-l border-bone/15 bg-void/35 text-bone/70 backdrop-blur-sm transition-colors duration-200 group-hover:bg-void/65 group-hover:text-acid">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" class="h-7 w-7"><path d="m9 18 6-6-6-6"></path></svg>
      </span>
      <span
        class="pointer-events-none mr-1 flex max-w-[40vw] translate-x-3 flex-col items-end gap-0.5 border border-line bg-void/85 px-3 py-2 opacity-0 backdrop-blur-sm transition-all duration-300 group-hover:translate-x-0 group-hover:opacity-100"
      >
        <span class="font-mono text-[10px] uppercase tracking-[0.16em] text-steel">Next / N&deg;{nextNo} &#8594;</span>
        <span class="truncate font-display text-[30px] uppercase leading-none" style={`color:${nextGlyph}`}>{next.title}</span>
      </span>
    </a>
  </main>
  <Footer />
</BaseLayout>

<script>
  // ←/→ cycle between specimens, reusing the page's prev/next links + view transition
  import { navigate } from "astro:transitions/client";
  if (!(window as any).__cycleKeysBound) {
    (window as any).__cycleKeysBound = true;
    document.addEventListener("keydown", (e) => {
      if (e.key !== "ArrowLeft" && e.key !== "ArrowRight") return;
      const tag = (e.target as HTMLElement | null)?.tagName;
      if (tag === "INPUT" || tag === "TEXTAREA" || (e.target as HTMLElement)?.isContentEditable) return;
      const sel = e.key === "ArrowLeft" ? '[data-cycle="prev"]' : '[data-cycle="next"]';
      const link = document.querySelector(sel) as HTMLAnchorElement | null;
      if (link) {
        e.preventDefault();
        navigate(link.href);
      }
    });
  }
</script>

<style is:global>
  /* slow, weighted morph of the colored poster as you cycle specimens */
  ::view-transition-group(dossier-poster) {
    animation-duration: 0.55s;
    animation-timing-function: cubic-bezier(0.76, 0, 0.24, 1);
  }
  ::view-transition-old(dossier-poster),
  ::view-transition-new(dossier-poster) {
    animation-duration: 0.55s;
  }
</style>
