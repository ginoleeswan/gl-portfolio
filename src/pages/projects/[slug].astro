---
import { Icon } from "astro-icon/components";
import { getCollection, render, type CollectionEntry } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";
import Nav from "../../components/astro/Nav.astro";
import Footer from "../../components/astro/Footer.astro";
import TechRow from "../../components/astro/TechRow.astro";
import { PROJECT_THEMES } from "../../lib/projectThemes";

export async function getStaticPaths() {
  const projects = await getCollection("projects");
  return projects.map((project) => ({ params: { slug: project.data.slug }, props: { project } }));
}

const { project } = Astro.props as { project: CollectionEntry<"projects"> };
const { title, tagline, techStack, liveUrl, repoUrl, slug, role, year, accent, kana, order } = project.data;
const { Content } = await render(project);

const t = PROJECT_THEMES[accent];
const no = String(order).padStart(2, "0");
const logoName = accent === "myth" ? "mythique" : accent === "glow" ? "glow" : "karma";
---

<BaseLayout title={title} description={tagline}>
  <Nav />
  <main>
    <!-- DUOTONE DOSSIER HEADER (real app palette) -->
    <header
      class="halftone relative overflow-hidden px-12 pb-12 pt-16"
      style={`view-transition-name: card-${slug}; background:
        radial-gradient(125% 125% at 16% 0%, ${t.bgFrom}, ${t.bgMid} 52%, ${t.bgTo})`}
    >
      <Icon
        name={logoName}
        class="pointer-events-none absolute -right-10 -top-10 z-[1] h-72 w-72 opacity-[0.12]"
        style={`color:${t.name}`}
      />
      <div class="relative z-[2] mx-auto max-w-5xl">
        <div class="flex items-center justify-between font-mono text-[11px] uppercase tracking-[0.14em]" style={`color:${t.chrome}`}>
          <a href="/#work" style={`color:${t.chrome}`}>&#8592; Index</a>
          <span>Dossier N&deg;{no} / {year}</span>
        </div>
        <div
          class="pointer-events-none absolute right-0 top-6 font-sub text-[60px] font-black leading-none opacity-90"
          style={`color:${t.glyph}; writing-mode: vertical-rl`}
        >
          {kana}
        </div>
        <div class="mt-8 flex items-center gap-4">
          <Icon name={logoName} class="h-14 w-14" style={`color:${t.name}`} />
          <span class="font-mono text-[12px] uppercase tracking-[0.18em]" style={`color:${t.body}`}>Specimen {no}</span>
        </div>
        <h1 class="mt-4 font-display text-[clamp(56px,11vw,150px)] uppercase leading-[0.82] tracking-[0.01em]" style={`color:${t.name}`}>
          {title}
        </h1>
        <p class="mt-4 max-w-[44ch] font-mono text-[14px] leading-relaxed" style={`color:${t.body}`}>{tagline}</p>
        <div class="mt-6 font-mono text-[11px] uppercase tracking-[0.12em]" style={`color:${t.body}`}>{role} &middot; {year}</div>
        <div class="mt-7 flex flex-wrap gap-3">
          {
            liveUrl && (
              <a
                href={liveUrl}
                target="_blank"
                rel="noopener noreferrer"
                class="bg-void px-5 py-2.5 font-sub text-[13px] font-black uppercase tracking-[0.04em] text-acid transition-transform hover:-translate-y-0.5"
              >
                Live demo &#8599;
              </a>
            )
          }
          <a
            href={repoUrl}
            target="_blank"
            rel="noopener noreferrer"
            class="border-2 px-5 py-2.5 font-sub text-[13px] font-black uppercase tracking-[0.04em] transition-transform hover:-translate-y-0.5"
            style={`border-color:${t.name}; color:${t.name}`}>GitHub &#8599;</a
          >
        </div>
      </div>
    </header>

    <!-- DOSSIER BODY -->
    <div class="mx-auto max-w-3xl px-12 py-16">
      <div class="mb-8 flex items-center gap-4 border-b border-line pb-3 font-mono text-[11px] uppercase tracking-[0.16em] text-steel">
        <span class="text-acid">// Dossier</span><span>Stack &mdash; hover for name</span>
      </div>
      <div class="mb-14">
        <TechRow items={techStack} />
      </div>
      <article class="dossier"><Content /></article>
    </div>
  </main>
  <Footer />
</BaseLayout>

<style is:global>
  .dossier {
    font-family: var(--font-mono);
    color: color-mix(in srgb, var(--color-bone) 85%, transparent);
    font-size: 14px;
    line-height: 1.8;
  }
  .dossier h2 {
    font-family: var(--font-sub);
    font-weight: 900;
    text-transform: uppercase;
    letter-spacing: 0.02em;
    font-size: 22px;
    color: var(--color-bone);
    margin: 2.5rem 0 0.75rem;
    padding-top: 1.5rem;
    border-top: 1px solid var(--color-line);
  }
  .dossier h2::before {
    content: "// ";
    color: var(--color-acid);
  }
  .dossier p {
    margin-bottom: 1rem;
    max-width: 64ch;
  }
  .dossier a {
    color: var(--color-acid);
    text-underline-offset: 3px;
    text-decoration: underline;
  }
  .dossier strong {
    color: var(--color-bone);
  }
</style>
