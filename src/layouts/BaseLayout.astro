---
import { ClientRouter } from "astro:transitions";
import "../styles/global.css";
import { buildMeta } from "../lib/seo";
import VercelAnalytics from "../components/react/Analytics";
import Backdrop from "../components/react/Backdrop";
const { title, description, image } = Astro.props;
const meta = buildMeta({ title, description, image });
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" type="image/x-icon" href="/favicon.ico" sizes="16x16 32x32 48x48" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
    <meta name="theme-color" content="#0a0b0a" />
    <title>{meta.title}</title>
    <meta name="description" content={meta.description} />
    <meta property="og:title" content={meta.title} />
    <meta property="og:description" content={meta.description} />
    <meta property="og:image" content={meta.ogImage} />
    <meta name="twitter:card" content="summary_large_image" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Archivo:wght@500;700;900&family=Space+Mono:wght@400;700&display=swap" rel="stylesheet" />
    <ClientRouter />
  </head>
  <body>
    <Backdrop client:idle mode="dither" />
    <div class="grain" aria-hidden="true"></div>
    <!-- top corners are framed by the sticky header; keep only the bottom registration marks -->
    <i class="crosshair crosshair-bl" aria-hidden="true"></i>
    <i class="crosshair crosshair-br" aria-hidden="true"></i>
    <div class="relative z-[1]"><slot /></div>
    <VercelAnalytics client:idle />
    <script>
      const RM = matchMedia("(prefers-reduced-motion: reduce)").matches;

      /* 1 — hover a card: its binary block scrambles, then resolves to the initials it encodes */
      function bindBinaryBlocks() {
        document.querySelectorAll<HTMLElement>("[data-binary]").forEach((block) => {
          if (block.dataset.bound) return;
          block.dataset.bound = "1";
          const card = block.closest("a") || block;
          const spans = [...block.querySelectorAll<HTMLElement>("span")];
          const original = spans.map((s) => s.textContent ?? "");
          const code = (block.dataset.code ?? "").padEnd(spans.length, " ");
          const rnd = () => Array.from({ length: 8 }, () => (Math.random() < 0.5 ? "0" : "1")).join("");
          let timers: number[] = [];
          const clear = () => { timers.forEach(clearTimeout); timers = []; };
          const settle = () => spans.forEach((s, i) => { s.textContent = code[i] || " "; s.style.textAlign = "center"; });
          card.addEventListener("mouseenter", () => {
            clear();
            if (RM) return settle();
            let t = 0;
            const tick = () => {
              spans.forEach((s) => { s.textContent = rnd(); s.style.textAlign = "left"; });
              t += 45;
              if (t < 450) timers.push(window.setTimeout(tick, 45));
              else settle();
            };
            tick();
          });
          card.addEventListener("mouseleave", () => {
            clear();
            spans.forEach((s, i) => { s.textContent = original[i]; s.style.textAlign = "left"; });
          });
        });
      }

      /* 2 — big wordmarks decrypt from random glyphs when they scroll into view */
      function bindScramble() {
        const glyphs = "ABCDEFGHIJKLMNOPQRSTUVWXYZ#%*/<>?01";
        const io = new IntersectionObserver((entries) => {
          entries.forEach((entry) => {
            if (!entry.isIntersecting) return;
            const el = entry.target as HTMLElement;
            io.unobserve(el);
            if (el.dataset.done) return;
            el.dataset.done = "1";
            const final = el.textContent ?? "";
            if (RM) return;
            let frame = 0;
            const run = () => {
              el.textContent = final
                .split("")
                .map((ch, i) => (ch === " " ? " " : i < frame / 2 ? final[i] : glyphs[(Math.random() * glyphs.length) | 0]))
                .join("");
              frame += 1;
              if (frame / 2 < final.length) window.setTimeout(() => requestAnimationFrame(run), 16);
              else el.textContent = final;
            };
            run();
          });
        }, { threshold: 0.4 });
        document.querySelectorAll<HTMLElement>("[data-scramble]:not([data-done])").forEach((el) => io.observe(el));
      }

      /* 3 — a note for anyone who opens devtools */
      function consoleSignature() {
        const tag = "background:#4de852;color:#0a0b0a;font-weight:900;padding:2px 7px;border-radius:2px";
        console.log("%c gl %c  you found the source.", tag, "color:#e9e7dd;font-weight:bold;font-size:13px");
        console.log("%c01000111 01101001 01101110 01101111%c  → \"Gino\"", "color:#4de852;font-family:monospace", "color:#7f857a");
        console.log("%cEvery project card hides its own initials in that binary block — hover one.\nThen try the Konami code. ↑↑↓↓←→←→ b a", "color:#9ca2d2;line-height:1.6");
        console.log("%c→ github.com/ginoleeswan", "color:#4de852");
      }

      /* 5 — Konami code: acid flash + a received-transmission card */
      function transmission() {
        if (document.getElementById("konami-overlay")) return;
        const flash = document.createElement("div");
        Object.assign(flash.style, { position: "fixed", inset: "0", zIndex: "9998", background: "var(--color-acid)", mixBlendMode: "difference", pointerEvents: "none" });
        document.body.appendChild(flash);
        flash.animate([{ opacity: 1 }, { opacity: 0 }], { duration: 520, easing: "ease-out" }).onfinish = () => flash.remove();

        const o = document.createElement("div");
        o.id = "konami-overlay";
        Object.assign(o.style, { position: "fixed", inset: "0", zIndex: "9999", display: "grid", placeItems: "center", background: "rgba(10,11,10,0.88)", cursor: "pointer", backdropFilter: "blur(2px)" });
        o.innerHTML = `<div style="text-align:center;font-family:var(--font-mono);color:#e9e7dd;padding:2rem;max-width:40ch">
          <div style="font-size:11px;letter-spacing:.2em;color:#4de852;text-transform:uppercase">// Transmission received</div>
          <div style="font-family:var(--font-display);font-size:clamp(56px,13vw,128px);text-transform:uppercase;line-height:.82;margin:.5rem 0 .7rem">Signal<br>locked.</div>
          <div style="font-size:12px;color:#7f857a;line-height:1.6">You decoded the sequence — same energy that hid the initials in the binary. Now go open the apps.</div>
          <div style="font-size:11px;color:#9ca2d2;margin-top:1.3rem;letter-spacing:.16em">[ click anywhere to close ]</div>
        </div>`;
        document.body.appendChild(o);
        o.animate([{ opacity: 0 }, { opacity: 1 }], { duration: 220 });
        const close = () => { o.animate([{ opacity: 1 }, { opacity: 0 }], { duration: 220 }).onfinish = () => o.remove(); };
        o.addEventListener("click", close);
        window.setTimeout(close, 4200);
      }

      function bindKonami() {
        const seq = ["arrowup", "arrowup", "arrowdown", "arrowdown", "arrowleft", "arrowright", "arrowleft", "arrowright", "b", "a"];
        let i = 0;
        window.addEventListener("keydown", (e) => {
          const k = e.key.toLowerCase();
          i = k === seq[i] ? i + 1 : k === seq[0] ? 1 : 0;
          if (i === seq.length) { i = 0; transmission(); }
        });
      }

      /* nav scroll-spy — light the matching link as #work / #contact pass the upper third */
      function bindNavSpy() {
        const links = [...document.querySelectorAll<HTMLElement>("[data-spy]")];
        const sections = ["work", "contact"].map((id) => document.getElementById(id)).filter(Boolean) as HTMLElement[];
        if (!links.length || !sections.length) return;
        const visible = new Set<string>();
        const setActive = (id?: string) =>
          links.forEach((l) => {
            const on = !!id && l.dataset.spy === id;
            l.classList.toggle("is-active", on);
            if (on) l.setAttribute("aria-current", "true");
            else if (l.getAttribute("aria-current") === "true") l.removeAttribute("aria-current");
          });
        const io = new IntersectionObserver(
          (entries) => {
            entries.forEach((e) => (e.isIntersecting ? visible.add(e.target.id) : visible.delete(e.target.id)));
            setActive(["work", "contact"].find((id) => visible.has(id)));
          },
          { rootMargin: "-45% 0px -50% 0px" }
        );
        sections.forEach((s) => io.observe(s));
      }

      // per-view features re-bind after every view transition; global hooks attach once
      document.addEventListener("astro:page-load", () => { bindBinaryBlocks(); bindScramble(); bindNavSpy(); });
      if (!(window as any).__glInit) {
        (window as any).__glInit = true;
        consoleSignature();
        bindKonami();
      }
    </script>
  </body>
</html>
