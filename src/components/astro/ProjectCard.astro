---
import type { CollectionEntry } from "astro:content";
const { project } = Astro.props as { project: CollectionEntry<"projects"> };
const { title, tagline, slug, accent, kana, order, techStack } = project.data;

// per-accent theming
const themes = {
  myth: { bg: "#1b4dff", glyph: "#37e0ff", chrome: "#cfe0ff", name: "#ffffff", body: "#d4e0ff", open: "#c6f53f", binary: "#37e0ff" },
  glow: { bg: "#ff2d87", glyph: "#ff7ab0", chrome: "#ffd6e8", name: "#ffffff", body: "#ffe0ee", open: "#c6f53f", binary: "#c6f53f" },
  karma: { bg: "#c6f53f", glyph: "#8ab02a", chrome: "#2c3a08", name: "#0a0b0a", body: "#2c3a08", open: "#0a0b0a", binary: "#0a0b0a" },
} as const;
const t = themes[accent];
const no = String(order).padStart(2, "0");
const primary = techStack[0];
---
<a
  href={`/projects/${slug}`}
  class="halftone reveal group relative flex min-h-[420px] flex-col overflow-hidden border border-white/15 p-6 no-underline transition-transform duration-200 hover:-translate-y-1"
  style={`view-transition-name: card-${slug}; background:
    radial-gradient(120% 120% at 20% 0%, color-mix(in srgb, ${t.bg} 70%, white), ${t.bg} 55%, color-mix(in srgb, ${t.bg} 60%, black))`}
>
  <div class="relative z-[2] flex items-start justify-between font-mono text-[10px] uppercase tracking-[0.12em]" style={`color:${t.chrome}`}>
    <span>SPEC_{no} / {project.data.year}</span>
    <span class="border px-2 py-1" style={`border-color:${t.chrome}`}>ACTIVE</span>
  </div>

  <div class="relative z-[2] mt-5 font-mono text-[13px] font-bold leading-[1.3] tracking-[0.12em]" style={`color:${t.binary}`}>
    01000111<br />01101001<br />01101110
  </div>
  <div
    class="absolute right-5 top-16 z-[2] font-sub text-[40px] font-black leading-[0.9]"
    style={`color:${t.glyph}; writing-mode: vertical-rl; letter-spacing:.05em`}
  >
    {kana}
  </div>

  <div
    class="absolute -right-8 bottom-28 z-[1] h-48 w-48 rounded-full opacity-50"
    style={`background: radial-gradient(circle at 35% 30%, white, ${t.glyph} 45%, ${t.bg} 100%)`}
  >
  </div>

  <!-- legibility scrim for body text -->
  <div class="pointer-events-none absolute inset-x-0 bottom-0 z-[1] h-1/2 bg-gradient-to-t from-black/55 to-transparent"></div>

  <div class="relative z-[2] mt-auto">
    <div class="font-mono text-[11px] font-bold uppercase tracking-[0.1em]" style={`color:${t.body}`}>
      N&deg;{no} &mdash; {primary}
    </div>
    <h3 class="mt-1.5 font-display text-[52px] uppercase leading-[0.82] tracking-[0.02em]" style={`color:${t.name}`}>
      {title}
    </h3>
    <p class="mt-3 max-w-[26ch] font-mono text-[11px] leading-relaxed" style={`color:${t.body}`}>{tagline}</p>
    <span class="mt-4 inline-flex items-center gap-2 font-mono text-[11px] font-bold uppercase tracking-[0.12em]" style={`color:${t.open}`}>
      Open dossier &#8599;
    </span>
  </div>
</a>
