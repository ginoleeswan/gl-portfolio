---
import { Icon } from "astro-icon/components";
import type { CollectionEntry } from "astro:content";
import { PROJECT_THEMES } from "../../lib/projectThemes";
const { project } = Astro.props as { project: CollectionEntry<"projects"> };
const { title, tagline, slug, accent, kana, order, techStack } = project.data;

const t = PROJECT_THEMES[accent];
const no = String(order).padStart(2, "0");
const primary = techStack[0];
---
<a
  href={`/projects/${slug}`}
  class="halftone reveal group relative flex min-h-[440px] flex-col overflow-hidden border border-white/15 p-6 no-underline transition-transform duration-200 hover:-translate-y-1"
  style={`background:
    radial-gradient(125% 125% at 18% 0%, ${t.bgFrom}, ${t.bgMid} 52%, ${t.bgTo})`}
>
  <!-- top chrome -->
  <div class="relative z-[2] flex items-start justify-between font-mono text-[10px] uppercase tracking-[0.12em]" style={`color:${t.chrome}`}>
    <span>SPEC_{no} / {project.data.year}</span>
    <span class="border px-2 py-1" style={`border-color:${t.chrome}`}>ACTIVE</span>
  </div>

  <!-- binary + kana -->
  <div class="relative z-[2] mt-5 font-mono text-[13px] font-bold leading-[1.3] tracking-[0.12em]" style={`color:${t.accent}`}>
    01000111<br />01101001<br />01101110
  </div>
  <div
    class="absolute right-5 top-16 z-[2] font-sub text-[40px] font-black leading-[0.9]"
    style={`color:${t.glyph}; writing-mode: vertical-rl; letter-spacing:.05em`}
  >
    {kana}
  </div>

  <!-- real app logo -->
  <Icon
    name={accent === "myth" ? "mythique" : accent === "glow" ? "glow" : "karma"}
    class="absolute -right-6 bottom-32 z-[1] h-44 w-44 opacity-[0.18]"
    style={`color:${t.logo}`}
  />

  <!-- bottom -->
  <div class="relative z-[2] mt-auto">
    <div class="mb-3 flex items-center gap-2">
      <Icon
        name={accent === "myth" ? "mythique" : accent === "glow" ? "glow" : "karma"}
        class="h-6 w-6"
        style={`color:${t.name}`}
      />
      <span class="font-mono text-[11px] font-bold uppercase tracking-[0.1em]" style={`color:${t.body}`}>
        N&deg;{no} &mdash; {primary}
      </span>
    </div>
    <h3 class="font-display text-[52px] uppercase leading-[0.82] tracking-[0.02em]" style={`view-transition-name: title-${slug}; color:${t.name}`}>
      {title}
    </h3>
    <p class="mt-3 max-w-[26ch] font-mono text-[11px] leading-relaxed" style={`color:${t.body}`}>{tagline}</p>
    <span class="mt-4 inline-flex items-center gap-2 font-mono text-[11px] font-bold uppercase tracking-[0.12em]" style={`color:${t.accent}`}>
      Open dossier &#8599;
    </span>
  </div>
</a>
