---
const links = [
  { label: "Index", href: "/", match: "/" },
  { label: "Work", href: "/#work", match: null },
  { label: "About", href: "/about", match: "/about" },
  { label: "Contact", href: "/#contact", match: null },
];
const pathname = Astro.url.pathname;
---
<nav
  class="sticky top-0 z-50 flex items-center justify-between border-b border-line bg-void/80 px-12 py-4 backdrop-blur"
>
  <a href="/" class="font-sub text-sm font-black tracking-tight text-bone">
    GINO<span class="text-acid">&#9670;</span>SWANEPOEL
  </a>
  <ul class="flex gap-6 font-mono text-[11px] uppercase tracking-[0.16em] text-steel">
    {
      links.map((l) => (
        <li>
          <a
            href={l.href}
            class:list={["transition-colors hover:text-acid", l.match === pathname && "text-acid"]}
          >
            {l.label}
          </a>
        </li>
      ))
    }
  </ul>
</nav>
