---
import { Icon } from "astro-icon/components";
import { SOCIALS, EMAIL } from "../../lib/social";
import { socialIcon } from "../../lib/icons";
const year = new Date().getFullYear();
---
<footer class="mt-32 border-t border-line px-5 py-10 font-mono text-[11px] text-steel sm:px-8 lg:px-12">
  <div class="mb-8 flex items-end justify-between gap-6">
    <div class="acid-stripe h-2 w-40"></div>
    <div class="barcode h-8 w-44 opacity-80"></div>
  </div>
  <div class="flex flex-wrap items-start justify-between gap-6 uppercase tracking-[0.12em]">
    <div class="space-y-1">
      <div class="flex items-center gap-2.5 font-sub text-sm font-black tracking-tight text-bone">
        <Icon name="gino" class="h-7 w-7 text-acid" />
        <span>GINO SWANEPOEL</span>
      </div>
      <div>&copy; {year} &middot; DESIGNER / DEVELOPER</div>
      <div>40.7440&deg;N 73.9873&deg;W &middot; ID 1696&middot;4567</div>
    </div>
    <ul class="flex flex-wrap gap-x-6 gap-y-2">
      {
        SOCIALS.map((s) => (
          <li>
            <a
              href={s.href}
              target="_blank"
              rel="noopener noreferrer"
              class="inline-flex items-center gap-1.5 transition-colors hover:text-acid"
            >
              {socialIcon(s.label) && <Icon name={socialIcon(s.label)!} class="h-3.5 w-3.5" />}
              {s.label} &#8599;
            </a>
          </li>
        ))
      }
      <li>
        <a href={`mailto:${EMAIL}`} class="text-bone transition-colors hover:text-acid">{EMAIL}</a>
      </li>
    </ul>
  </div>
</footer>
