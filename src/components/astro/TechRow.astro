---
import { Icon } from "astro-icon/components";
import { techIcon } from "../../lib/icons";
const { items } = Astro.props as { items: string[] };

// Visible, scannable stack: every tech gets a labeled chip — logo when one
// exists, name always shown. Recruiters read the stack at a glance; nothing
// hides behind a hover (which doesn't exist on touch) and nothing gets dropped.
const chips = items.map((name) => ({ name, icon: techIcon(name) }));
---
<div class="flex flex-wrap gap-2">
  {
    chips.map(({ name, icon }) => (
      <span class="inline-flex items-center gap-2 border border-line px-3 py-1.5 font-mono text-[11px] uppercase tracking-[0.08em] text-bone/75 transition-colors duration-150 hover:border-acid hover:text-acid">
        {icon && <Icon name={icon} class="h-3.5 w-3.5 shrink-0" />}
        {name}
      </span>
    ))
  }
</div>
