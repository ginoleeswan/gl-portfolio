---
import { Icon } from "astro-icon/components";
import { techIcon } from "../../lib/icons";
const { items } = Astro.props as { items: string[] };
---
<div class="flex flex-wrap items-center gap-x-7 gap-y-5">
  {
    items.map((name) => {
      const icon = techIcon(name);
      return icon ? (
        <span class="group relative inline-flex items-center" tabindex="0" aria-label={name}>
          <Icon
            name={icon}
            class="h-7 w-7 text-steel transition-colors duration-150 group-hover:text-acid group-focus-visible:text-acid"
          />
          <span class="pointer-events-none absolute -top-8 left-1/2 -translate-x-1/2 whitespace-nowrap border border-acid bg-void px-2 py-1 font-mono text-[10px] uppercase tracking-[0.1em] text-acid opacity-0 transition-opacity duration-150 group-hover:opacity-100 group-focus-visible:opacity-100">
            {name}
          </span>
        </span>
      ) : (
        <span class="border border-line px-2.5 py-1 font-mono text-[10px] uppercase tracking-[0.1em] text-steel">
          {name}
        </span>
      );
    })
  }
</div>
